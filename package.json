{
  "name": "landing-page",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "18.x",
    "npm": "9.x"
  },
  "dependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@stripe/react-stripe-js": "^3.1.1",
    "@stripe/stripe-js": "^5.4.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "firebase": "^10.7.1",
    "firebase-admin": "^13.0.2",
    "path": "^0.12.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.1.1",
    "react-scripts": "5.0.1",
    "stripe": "^17.5.0",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "react-snap": "^1.23.0",
    "webpack-dev-server": "^4.15.1"
  },
  "scripts": {
    "dev": "react-scripts start",
    "start": "node server.js",
    "build": "GENERATE_SOURCEMAP=false react-scripts build",
    "postbuild": "react-snap",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "heroku-postbuild": "GENERATE_SOURCEMAP=false npm run build"
  },
  "reactSnap": {
    "source": "build",
    "minifyHtml": { "collapseWhitespace": false },
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "crawl": true,
    "include": [
      "/",
      "/blog",
      "/pricing",
      "/blog/record-childs-voice-before-it-changes",
      "/blog/childhood-amnesia-why-toddler-wont-remember",
      "/blog/20-things-to-record-child-saying",
      "/blog/why-does-time-go-so-fast-with-kids",
      "/blog/sunday-recording-habit",
      "/blog/do-babies-recognize-parents-voices",
      "/blog/unique-gifts-new-parents",
      "/blog/things-to-remember-about-3-year-old",
      "/blog/meaningful-mothers-day-gifts",
      "/blog/best-family-memory-apps-2026",
      "/blog/time-capsule-for-your-child",
      "/blog/the-voice-thats-changing-right-now"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
